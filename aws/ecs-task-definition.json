{
  "family": "ai-studymate-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::848865119413:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::848865119413:role/ai-studymate-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "ai-studymate-backend",
      "image": "848865119413.dkr.ecr.eu-north-1.amazonaws.com/ai-studymate-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "GEMINI_API_KEY",
          "value": "PLACEHOLDER_GEMINI_API_KEY"
        },
        {
          "name": "EMAIL_LAMBDA_FUNCTION_NAME",
          "value": "ai-studymate-email-lambda"
        },
        {
          "name": "AWS_REGION",
          "value": "eu-north-1"
        },
        {
          "name": "CORS_ORIGINS",
          "value": "*"
        }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:8000/health')\""
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 20
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ai-studymate-backend",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}